{
  "name": "360-virtual-tour-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "tunnel": "node --env-file=.env scripts/tunnel.mjs",
    "demo": "npm run build && concurrently -k -n preview,tunnel \"npm run preview\" \"npm run tunnel\""
  },
  "dependencies": {
    "@photo-sphere-viewer/core": "^5.11.5",
    "@photo-sphere-viewer/gyroscope-plugin": "^5.11.5",
    "@photo-sphere-viewer/markers-plugin": "^5.11.5",
    "@photo-sphere-viewer/virtual-tour-plugin": "^5.11.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@ngrok/ngrok": "^1.7.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.3",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.8"
  }
}
